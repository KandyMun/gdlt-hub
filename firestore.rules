rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }

    // The hardcoded super-admin always has full access.
    function isSuper() {
      return isSignedIn() && request.auth.uid == "iG5pZlJrNYSyU7IONYNnoo3XFYp2";
    }

    // Roles assigned to the requesting user (empty list if none / no doc).
    function myRoles() {
      return isSignedIn()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('roles', [])
        : [];
    }
    function hasRole(r) { return myRoles().hasAny([r]); }

    // Super-admin or the `administrator` role = full site admin.
    function isAdmin() { return isSuper() || hasRole('administrator'); }

    // Only these keys differ between the incoming and stored doc.
    function changedOnly(keys) {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(keys);
    }

    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.authorId == request.auth.uid;
      // any logged-in user can like/dislike; author or admin can edit/delete
      allow update: if request.auth != null;
      allow delete: if request.auth != null
                    && (resource.data.authorId == request.auth.uid || isAdmin());

      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        allow update: if request.auth != null
                      && request.auth.uid == resource.data.authorId;
        allow delete: if request.auth != null
                      && (request.auth.uid == resource.data.authorId || isAdmin());
      }
    }

    match /config/{doc} {
      allow read: if true;
      // Rules text is editable by list staff; other config stays admin-only.
      allow write: if isAdmin() || (doc == 'ltclRules' && hasRole('list-admin'));
    }

    match /users/{uid} {
      // Public: usernames, avatars, roles, etc. are shown to logged-out
      // visitors too (feed, LTCL, profiles, bounty board).
      allow read: if true;
      allow create: if request.auth != null
                    && (request.auth.uid == uid || isAdmin());
      // A user may edit their own profile but NOT their roles or badges (no
      // self-promotion / self-awarding). Only admins can change those or ban.
      allow update: if isAdmin()
                    || (request.auth != null && request.auth.uid == uid
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['roles', 'banned', 'badges']));
    }

    match /notifications/{id} {
      allow read, update, delete: if request.auth != null
                                  && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null;
    }

    // Cosmetic badge definitions: anyone can read, only admins define them.
    match /badges/{badgeId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // LTCL level list. Anyone can read. list-admins have full control;
    // list-moderators may only change the records array (curating completions).
    match /levels/{levelId} {
      allow read: if true;
      allow create, delete: if isAdmin() || hasRole('list-admin');
      allow update: if isAdmin() || hasRole('list-admin')
                    || (hasRole('list-moderator') && changedOnly(['records']));
    }

    // Bounty Board. Anyone can read/post a bounty (money changes hands
    // externally between poster and completer). The poster may edit/cancel
    // their own bounty while it's still open; only the bounty-board-manager
    // role (or admin) may mark one completed/reopen it, since they're the
    // one confirming the reward was actually paid out.
    function isBountyManager() { return isAdmin() || hasRole('bounty-board-manager'); }

    match /bounties/{bountyId} {
      allow read: if true;
      allow create: if request.auth != null
                    && request.resource.data.posterId == request.auth.uid
                    && request.resource.data.status == 'open'
                    && request.resource.data.amount is number
                    && request.resource.data.amount >= 2;
      allow update: if request.auth != null
                    && (
                      (resource.data.posterId == request.auth.uid
                        && resource.data.status == 'open'
                        && changedOnly(['levelName', 'levelId', 'aredlUrl', 'amount', 'description'])
                        && request.resource.data.amount is number
                        && request.resource.data.amount >= 2)
                      || isBountyManager()
                    );
      // Poster may cancel their own bounty only while it's still open; the
      // manager/admin can remove one (e.g. spam) regardless of status.
      allow delete: if request.auth != null
                    && ((resource.data.posterId == request.auth.uid && resource.data.status == 'open')
                        || isBountyManager());
    }
  }
}
